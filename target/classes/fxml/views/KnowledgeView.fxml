<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.focusnode.controller.KnowledgeViewController">
    
    <ScrollPane fx:id="notesScrollPane" fitToWidth="true" style="-fx-background-color: #F8FAFC;">
        <HBox spacing="30" style="-fx-padding: 30; -fx-background-color: #F8FAFC;">
        
        <!-- Sidebar Trái -->
        <VBox spacing="10" minWidth="200" prefWidth="220" style="-fx-background-color: transparent;">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-item, sidebar-item-active" fx:id="myDriveSidebarBtn" onMouseClicked="#openMyDrive">
                <Label text="🏠" style="-fx-font-size: 18px;" />
                <Label text="My Drive" style="-fx-font-size: 15px; -fx-font-weight: bold;" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-item" fx:id="trashSidebarBtn" onMouseClicked="#openTrash">
                <Label text="🗑" style="-fx-font-size: 18px;" />
                <Label text="Trash" style="-fx-font-size: 15px; -fx-font-weight: bold;" />
            </HBox>
        </VBox>
        
        <!-- Cột Giữa (Nội dung chính) -->
        <VBox spacing="20" HBox.hgrow="ALWAYS">
            
            <!-- Tiêu đề & Breadcrumb -->
            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #1F2937;" text="My Drive" />
                </HBox>
                <HBox fx:id="breadcrumbContainer" alignment="CENTER_LEFT" spacing="5" style="-fx-padding: 0 0 10 0;">
                    <Label style="-fx-font-size: 14px; -fx-text-fill: #3B82F6; -fx-cursor: hand;" text="My Drive" />
                    <Label style="-fx-font-size: 14px; -fx-text-fill: #6B7280;" text="&gt;" />
                    <!-- Breadcrumbs will be added here dynamically -->
                </HBox>
            </VBox>
            
            <!-- Thanh Công cụ (Search, Toggles, Filter) -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <TextField fx:id="searchInput" prefWidth="350" promptText="🔍 Search in Drive..." styleClass="search-bar" />
                
                <Region HBox.hgrow="ALWAYS" />
                
                <!-- Toggles -->
                <HBox spacing="5" styleClass="view-toggle-container">
                    <Label fx:id="gridViewBtn" styleClass="toggle-btn, toggle-btn-active" text="⊞" style="-fx-font-size: 18px; -fx-cursor: hand;" />
                    <Label fx:id="listViewBtn" styleClass="toggle-btn" text="≡" style="-fx-font-size: 18px; -fx-cursor: hand;" />
                </HBox>
                
                <Label styleClass="btn-outline" text="⚙ Filter" />
                <MenuButton fx:id="newBtn" styleClass="btn-new-note" text="+ New">
                    <items>
                        <MenuItem text="New Folder" onAction="#createNewFolder" />
                        <MenuItem text="New Note" onAction="#createNewNote" />
                        <SeparatorMenuItem />
                        <MenuItem text="Upload File" onAction="#uploadFile" />
                    </items>
                </MenuButton>
            </HBox>
            
            <!-- Quick Filters -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0;">
                <Label style="-fx-text-fill: #6B7280; -fx-font-size: 13px;" text="Quick Filters:" />
                <Label styleClass="quick-filter-btn, quick-filter-btn-active" text="All" />
                <Label styleClass="quick-filter-btn" text="#study" />
                <Label styleClass="quick-filter-btn" text="#project" />
                <Label styleClass="quick-filter-btn" text="#java" />
                <Label styleClass="quick-filter-btn" text="#network" />
                <Label styleClass="quick-filter-btn" text="#ai" />
                <Label styleClass="quick-filter-btn" text="..." />
            </HBox>
            
            <!-- Vùng hiển thị (Grid/List) -->
            <StackPane fx:id="contentContainer" VBox.vgrow="ALWAYS">
                <!-- Lưới Ghi chú và File (Grid View) -->
                <FlowPane fx:id="notesFlowPane" hgap="20" vgap="20" />
                
                <!-- Danh sách Ghi chú và File (List View) -->
                <VBox fx:id="listViewContainer" spacing="10" visible="false">
                    <!-- Header -->
                    <HBox style="-fx-padding: 10; -fx-border-color: transparent transparent #E5E7EB transparent; -fx-border-width: 0 0 1 0;">
                        <Label text="Name" style="-fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-pref-width: 400;" />
                        <Label text="Type" style="-fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-pref-width: 150;" />
                        <Label text="Last Modified" style="-fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-pref-width: 150;" />
                    </HBox>
                    <!-- List Items -->
                    <VBox fx:id="listItemsBox" spacing="5" />
                </VBox>
            </StackPane>
        </VBox>
        
        <!-- Cột Phải (Widgets) -->
        <VBox minWidth="300" prefWidth="300" spacing="20">
            <fx:include source="../components/QuoteCard.fxml" />
            <fx:include source="../components/QuickNoteCard.fxml" />
            <fx:include source="../components/TagsCloudCard.fxml" />
            <fx:include source="../components/StorageCard.fxml" />
        </VBox>
        
    </HBox>
    </ScrollPane>

    <!-- Editor Container (Modal) -->
    <StackPane fx:id="editorContainer" visible="false" style="-fx-background-color: rgba(0,0,0,0.5);" />

</StackPane>
