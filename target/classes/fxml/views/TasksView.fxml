<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    
    <HBox spacing="30" style="-fx-padding: 30; -fx-background-color: #F8FAFC;">
        
        <!-- Cột Trái (Nội dung chính) -->
        <VBox spacing="20" HBox.hgrow="ALWAYS">
            
            <!-- Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #1F2937;" text="Tasks 📋" />
                    <Label style="-fx-font-size: 14px; -fx-text-fill: #6B7280;" text="Plan your day. Focus on what matters." />
                </VBox>
                
                <Region HBox.hgrow="ALWAYS" />
                
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label styleClass="btn-new-note" text="+ New Task ⌄" />
                    <!-- Toggles -->
                    <HBox spacing="5">
                        <Label styleClass="toggle-btn" text="≡" style="-fx-font-size: 18px;" />
                        <Label styleClass="toggle-btn" text="📅" style="-fx-font-size: 16px;" />
                    </HBox>
                </HBox>
            </HBox>
            
            <!-- Stats Row -->
            <HBox spacing="20">
                <fx:include source="../components/TaskStatCard.fxml" />
                
                <!-- In Progress Stat -->
                <HBox spacing="15" alignment="CENTER_LEFT" styleClass="task-stat-card">
                    <VBox styleClass="stat-icon-wrapper" style="-fx-background-color: #EFF6FF;">
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #3B82F6;" text="🎯" />
                    </VBox>
                    <VBox spacing="2">
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F2937;" text="8" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" text="In Progress" />
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #94A3B8;" text="Ongoing" />
                    </VBox>
                </HBox>
                
                <!-- Pending Stat -->
                <HBox spacing="15" alignment="CENTER_LEFT" styleClass="task-stat-card">
                    <VBox styleClass="stat-icon-wrapper" style="-fx-background-color: #FFFBEB;">
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #F59E0B;" text="⏱" />
                    </VBox>
                    <VBox spacing="2">
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F2937;" text="3" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" text="Pending" />
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #94A3B8;" text="Upcoming" />
                    </VBox>
                </HBox>

                <!-- Total Stat -->
                <HBox spacing="15" alignment="CENTER_LEFT" styleClass="task-stat-card">
                    <VBox styleClass="stat-icon-wrapper" style="-fx-background-color: #F3E8FF;">
                        <Label style="-fx-font-size: 16px; -fx-text-fill: #9333EA;" text="📅" />
                    </VBox>
                    <VBox spacing="2">
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F2937;" text="18" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" text="Total Tasks" />
                        <Label style="-fx-font-size: 10px; -fx-text-fill: #94A3B8;" text="This Week" />
                    </VBox>
                </HBox>
            </HBox>
            
            <!-- Filters & Search -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <HBox spacing="10">
                    <Label styleClass="quick-filter-btn, quick-filter-btn-active" text="All" />
                    <Label styleClass="quick-filter-btn" text="Today" />
                    <Label styleClass="quick-filter-btn" text="Upcoming" />
                    <Label styleClass="quick-filter-btn" text="Completed" />
                </HBox>
                
                <Region HBox.hgrow="ALWAYS" />
                
                <TextField prefWidth="250" promptText="🔍 Search tasks..." styleClass="search-bar" />
                <Label styleClass="btn-outline" text="⚙ Filter" />
            </HBox>
            
            <!-- Task List -->
            <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 2); -fx-padding: 10;">
                
                <!-- Table Header -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
                    <HBox alignment="CENTER" prefWidth="50">
                        <Label style="-fx-border-color: #CBD5E1; -fx-border-radius: 4; -fx-pref-width: 14; -fx-pref-height: 14;" />
                    </HBox>
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1F2937;" prefWidth="250" text="Task" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1F2937;" prefWidth="120" text="Status" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1F2937;" prefWidth="100" text="Priority" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1F2937;" prefWidth="120" text="Due Date" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1F2937;" prefWidth="100" text="Focus Time" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1F2937;" prefWidth="50" alignment="CENTER" text="Actions" />
                </HBox>
                
                <!-- Task Rows -->
                <fx:include source="../components/TaskRowItem.fxml" />
                
                <!-- Mock In Progress Row -->
                <HBox alignment="CENTER_LEFT" styleClass="task-row">
                    <HBox alignment="CENTER" prefWidth="50">
                        <VBox styleClass="task-checkbox, task-checkbox-circle" style="-fx-border-color: #3B82F6;" />
                    </HBox>
                    <VBox spacing="2" prefWidth="250">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1F2937;" text="Review knowledge base UI" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" text="Review" />
                    </VBox>
                    <HBox prefWidth="120" alignment="CENTER_LEFT">
                        <Label styleClass="status-badge-inprogress" text="In Progress" />
                    </HBox>
                    <HBox prefWidth="100" alignment="CENTER_LEFT" spacing="5">
                        <Label styleClass="priority-medium" text="— Medium" />
                    </HBox>
                    <HBox prefWidth="120" alignment="CENTER_LEFT">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="May 24, 2025" />
                    </HBox>
                    <HBox prefWidth="100" alignment="CENTER_LEFT" spacing="5">
                        <Label style="-fx-text-fill: #6B7280;" text="⏱" />
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #1F2937;" text="45 min" />
                    </HBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" prefWidth="50">
                        <Label styleClass="btn-icon-transparent" text="⋯" />
                    </HBox>
                </HBox>

                <!-- Mock Pending Row -->
                <HBox alignment="CENTER_LEFT" styleClass="task-row">
                    <HBox alignment="CENTER" prefWidth="50">
                        <VBox styleClass="task-checkbox, task-checkbox-circle" style="-fx-border-color: #CBD5E1;" />
                    </HBox>
                    <VBox spacing="2" prefWidth="250">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1F2937;" text="Read AI research papers" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" text="Study" />
                    </VBox>
                    <HBox prefWidth="120" alignment="CENTER_LEFT">
                        <Label styleClass="status-badge-pending" text="Pending" />
                    </HBox>
                    <HBox prefWidth="100" alignment="CENTER_LEFT" spacing="5">
                        <Label styleClass="priority-medium" text="— Medium" />
                    </HBox>
                    <HBox prefWidth="120" alignment="CENTER_LEFT">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="May 27, 2025" />
                    </HBox>
                    <HBox prefWidth="100" alignment="CENTER_LEFT" spacing="5">
                        <Label style="-fx-text-fill: #6B7280;" text="⏱" />
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #1F2937;" text="50 min" />
                    </HBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" prefWidth="50">
                        <Label styleClass="btn-icon-transparent" text="⋯" />
                    </HBox>
                </HBox>

                <!-- Footer / Pagination -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 15 10 5 10;">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="Showing 1-8 of 18 tasks" />
                    <Region HBox.hgrow="ALWAYS" />
                    
                    <HBox spacing="5" alignment="CENTER">
                        <Label styleClass="pagination-btn" text="&lt;" />
                        <Label styleClass="pagination-btn, pagination-btn-active" text="1" />
                        <Label styleClass="pagination-btn" text="2" />
                        <Label styleClass="pagination-btn" text="3" />
                        <Label styleClass="pagination-btn" text="&gt;" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS" />
                    
                    <HBox alignment="CENTER" spacing="5">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="Show" />
                        <Label styleClass="btn-outline" style="-fx-padding: 2 8;" text="10 ⌄" />
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="per page" />
                    </HBox>
                </HBox>
            </VBox>
        </VBox>
        
        <!-- Cột Phải (Widgets) -->
        <VBox minWidth="300" prefWidth="300" spacing="20">
            <fx:include source="../components/QuoteCard.fxml" />
            <fx:include source="../components/QuickNoteCard.fxml" />
            <fx:include source="../components/DailyStreakCard.fxml" />
        </VBox>
        
    </HBox>
</ScrollPane>
