<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox spacing="15" style="-fx-padding: 12px 18px; -fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    
    <!-- Cột trái (Cuộn được, chứa Header, Today's Focus, Pomodoro, Recent Notes) -->
    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="12">
            <!-- Header: Lời chào -->
            <fx:include source="../components/Header.fxml"/>

            <!-- Today's Focus và Pomodoro -->
            <HBox spacing="15">
                <VBox HBox.hgrow="ALWAYS">
                    <fx:include source="../components/TodaysFocusCard.fxml"/>
                </VBox>
                <VBox style="-fx-min-width: 250;">
                    <fx:include source="../components/PomodoroCard.fxml"/>
                </VBox>
            </HBox>

            <!-- Recent Notes -->
            <fx:include source="../components/RecentNotesSection.fxml"/>
        </VBox>
    </ScrollPane>

    <!-- Cột phải (Cố định, không cuộn) -->
    <VBox spacing="12" style="-fx-pref-width: 320; -fx-min-width: 320;">
        <fx:include source="../components/QuoteCard.fxml"/>
        <fx:include source="../components/QuickNoteCard.fxml"/>
        <fx:include source="../components/DailyStreakCard.fxml"/>
    </VBox>

</HBox>