<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<ScrollPane fitToHeight="true"
            fitToWidth="true"
            hbarPolicy="AS_NEEDED"
            styleClass="zen-scroll"
            vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1">
    <StackPane minHeight="560" minWidth="760" styleClass="zen-root">
        <Pane mouseTransparent="true">
            <Rectangle arcHeight="180" arcWidth="180" fill="#DDF7EE" height="170" opacity="0.75" width="720" x="-80" y="520" />
            <Rectangle arcHeight="180" arcWidth="180" fill="#DBEAFE" height="190" opacity="0.75" width="780" x="470" y="500" />
            <Circle centerX="170" centerY="170" fill="#FFFFFF" opacity="0.26" radius="120" />
            <Circle centerX="880" centerY="115" fill="#FFFFFF" opacity="0.34" radius="95" />
        </Pane>

        <VBox spacing="14" styleClass="zen-content">
            <fx:include source="../components/ZenHeader.fxml" />

            <HBox alignment="CENTER" spacing="16" VBox.vgrow="ALWAYS">
                <fx:include source="../components/ZenSessionPlanCard.fxml" />

                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                    <fx:include source="../components/ZenTimerPanel.fxml" />
                </VBox>

                <VBox maxWidth="230" minWidth="205" prefWidth="220" spacing="12">
                    <fx:include source="../components/ZenTeamFocusCard.fxml" />
                    <fx:include source="../components/ZenFocusTipsCard.fxml" />
                </VBox>
            </HBox>

            <fx:include source="../components/ZenControls.fxml" />
            <fx:include source="../components/ZenBottomBar.fxml" />
        </VBox>
    </StackPane>
</ScrollPane>
