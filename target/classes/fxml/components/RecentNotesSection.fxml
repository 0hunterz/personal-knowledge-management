<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.focusnode.controller.RecentNotesController">
    
    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fitHeight="20" fitWidth="20" pickOnBounds="true" preserveRatio="true">
            <image><Image url="@/images/note.png" /></image>
        </ImageView>
        <Label text="Recent Notes" styleClass="card-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="View all →" styleClass="btn-text" onAction="#viewAllNotes" />
    </HBox>

    <!-- HBox chứa các NoteCard nằm ngang, có thể bọc trong ScrollPane nếu nhiều -->
    <HBox spacing="15" fx:id="notesContainer">
        <!-- Notes will be loaded here dynamically by controller -->
    </HBox>

</VBox>