<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="card" stylesheets="@../../css/styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">

    <HBox alignment="CENTER_LEFT" spacing="10" stylesheets="@../../css/styles.css">
        
        <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../images/target-icon.png" /> 
            </image>
        </ImageView>

        <Label styleClass="card-title" text="Today's Focus" />

        <Region HBox.hgrow="ALWAYS" />

        <Button styleClass="btn-add-task" text="+ Add Task" />
        
    </HBox>

    <VBox fx:id="taskListContainer" spacing="12" stylesheets="@../../css/styles.css">
        </VBox>

</VBox>
