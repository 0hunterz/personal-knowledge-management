<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<!-- Card dùng ảnh nền quote.png -->
<VBox spacing="10" styleClass="card" alignment="CENTER_LEFT" style="-fx-background-image: url('/images/quote.png'); -fx-background-size: cover; -fx-background-position: center; -fx-background-repeat: no-repeat; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4); -fx-padding: 100 25 30 25;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.focusnode.controller.QuoteController">
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Quote of the day" styleClass="card-title" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="⋮" style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-cursor: hand; -fx-text-fill: #64748B;" />
    </HBox>

    <Label fx:id="quoteText" text="&#34;Loading quote...&#34;" wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #1E293B; -fx-line-spacing: 5px; -fx-font-weight: 500;" />
    
    <Label fx:id="quoteAuthor" text="— Please wait" style="-fx-font-size: 12px; -fx-text-fill: #64748B; -fx-font-style: italic;" />
</VBox>