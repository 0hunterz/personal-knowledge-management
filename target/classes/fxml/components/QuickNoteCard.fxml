<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox spacing="8" styleClass="card" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.focusnode.controller.QuickNoteController">
    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fitHeight="24" fitWidth="24" pickOnBounds="true" preserveRatio="true">
            <image><Image url="@/images/work-order.png" /></image>
        </ImageView>
        <Label text="Quick Note" styleClass="card-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="⋮" style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-cursor: hand; -fx-text-fill: #6B7280;" />
    </HBox>

    <TextArea fx:id="noteArea" promptText="Write something...&#10;(press Enter to save)" wrapText="true" prefRowCount="2" style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-control-inner-background: #F8FAFC;" />

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Label fx:id="charCountLabel" text="0 / 200" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;" />
        <Button text="Save Note" style="-fx-background-color: #DCFCE7; -fx-text-fill: #22C55E; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand;" onAction="#saveQuickNote" />
    </HBox>
</VBox>