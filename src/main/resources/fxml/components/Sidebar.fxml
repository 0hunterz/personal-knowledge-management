<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="250" spacing="12" style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-width: 0 1 0 0;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.focusnode.controller.SidebarController">
    <padding>
        <Insets top="20" right="14" bottom="20" left="14"/>
    </padding>

    <!-- Logo Area -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 0 0 25 0;">
        <StackPane styleClass="sidebar-logo-frame" style="-fx-background-color: transparent; -fx-background-radius: 12;">
            <ImageView fitWidth="64" fitHeight="64" preserveRatio="true" smooth="true" pickOnBounds="true">
                <image>
                    <Image url="@/images/logo.png" />
                </image>
            </ImageView>
        </StackPane>
        <VBox alignment="CENTER_LEFT" spacing="2">
            <Label text="Focus-Node" style="-fx-font-weight: 800; -fx-font-size: 20px; -fx-text-fill: #0F172A;" />
            <Label text="Focus. Learn. Grow." style="-fx-font-size: 11px; -fx-text-fill: #64748B;" />
        </VBox>
    </HBox>

    <!-- Navigation Menu Container -->
    <VBox spacing="4" VBox.vgrow="ALWAYS">
        <fx:define>
            <ToggleGroup fx:id="menuGroup"/>
        </fx:define>
        <!-- Home -->
        <ToggleButton text="Home" toggleGroup="$menuGroup" selected="true" styleClass="nav-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" onAction="#showHome">
            <graphic>
                <ImageView fitHeight="22" fitWidth="22" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/Home.png" /></image></ImageView>
            </graphic>
        </ToggleButton>
        <!-- Knowledge -->
        <ToggleButton text="Knowledge" toggleGroup="$menuGroup" styleClass="nav-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" onAction="#showKnowledge">
            <graphic>
                <ImageView fitHeight="22" fitWidth="22" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/Knowledge.png" /></image></ImageView>
            </graphic>
        </ToggleButton>
        <!-- LAN Hub -->
        <ToggleButton text="LAN Hub" toggleGroup="$menuGroup" styleClass="nav-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" onAction="#showLanHub">
            <graphic>
                <ImageView fitHeight="22" fitWidth="22" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/LAN-Hub.png" /></image></ImageView>
            </graphic>
        </ToggleButton>
        <Separator style="-fx-padding: 10 0;" />
        <!-- Tasks -->
        <ToggleButton text="Tasks" toggleGroup="$menuGroup" styleClass="nav-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" onAction="#showTasks">
            <graphic>
                <ImageView fitHeight="22" fitWidth="22" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/Tasks.png" /></image></ImageView>
            </graphic>
        </ToggleButton>
        <!-- Zen Mode -->
        <ToggleButton text="Zen Mode" toggleGroup="$menuGroup" styleClass="nav-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" onAction="#showZenMode">
            <graphic>
                <ImageView fitHeight="22" fitWidth="22" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/Focus.png" /></image></ImageView>
            </graphic>
        </ToggleButton>
        <!-- Tags -->
        <ToggleButton text="Tags" toggleGroup="$menuGroup" styleClass="nav-btn" maxWidth="Infinity" alignment="BASELINE_LEFT" onAction="#showTags">
            <graphic>
                <ImageView fitHeight="22" fitWidth="22" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/Tags.png" /></image></ImageView>
            </graphic>
        </ToggleButton>
        <Separator style="-fx-padding: 10 0;" />
        <!-- Settings -->
        <ToggleButton text="Settings" toggleGroup="$menuGroup" styleClass="nav-btn" maxWidth="Infinity" alignment="BASELINE_LEFT">
            <graphic>
                <ImageView fitHeight="22" fitWidth="22" pickOnBounds="true" preserveRatio="true"><image><Image url="@/images/Settings.png" /></image></ImageView>
            </graphic>
        </ToggleButton>
        
        <!-- Spacer to push profile to bottom -->
        <Region VBox.vgrow="ALWAYS" />
    </VBox>

    <!-- User Profile at Bottom -->
    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="user-profile-btn">
        <StackPane style="-fx-effect: dropshadow(three-pass-box, rgba(139, 92, 246, 0.2), 6, 0, 0, 2);">
            <Circle radius="16" fill="#8B5CF6" />
            <Label text="U" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;" />
        </StackPane>
        <VBox spacing="1">
            <Label text="User" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1E293B;" />
            <Label text="Focus every day" style="-fx-font-size: 10px; -fx-text-fill: #64748B;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label text="›" style="-fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-font-size: 16px;" />
    </HBox>
</VBox>