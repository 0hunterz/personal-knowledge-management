<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<!-- Một Note Card độc lập -->

<VBox minWidth="200" prefWidth="220" spacing="10" style="-fx-padding: 15; -fx-cursor: hand;" styleClass="card" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.focusnode.controller.NoteCardController">
    <!-- Icon mảng -->
    <HBox>
        <StackPane alignment="CENTER">
            <Region fx:id="iconBackground" style="-fx-background-color: #E0F2FE; -fx-background-radius: 12; -fx-pref-width: 44; -fx-pref-height: 44;" />
            <ImageView fx:id="iconImageView" fitHeight="22" fitWidth="22" pickOnBounds="true" preserveRatio="true">
                <image><Image url="@/images/note.png" /></image>
            </ImageView>
        </StackPane>
    </HBox>

    <!-- Tiêu đề -->
    <Label fx:id="titleLabel" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" text="Project Plan" />

    <!-- Nội dung mô tả ngắn -->
    <Label fx:id="previewLabel" maxHeight="70" prefHeight="65" style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-line-spacing: 3px;" text="## Overview&#10;This project aims to build a LAN focus room application..." wrapText="true" textOverrun="ELLIPSIS" alignment="TOP_LEFT" />

    <Region VBox.vgrow="ALWAYS" />

    <!-- Tags -->
    <HBox fx:id="tagsContainer" spacing="8">
        <Label style="-fx-background-color: #E0F2FE; -fx-text-fill: #0284C7;" styleClass="tag-badge" text="#project" />
        <Label style="-fx-background-color: #E0F2FE; -fx-text-fill: #0284C7;" styleClass="tag-badge" text="#plan" />
    </HBox>

    <!-- Thời gian cập nhật -->
    <Label fx:id="updatedAtLabel" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-padding: 5 0 0 0;" text="Updated 2h ago" />
</VBox>
