<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<!-- Trạng thái mặc định: Chưa hoàn thành (Màu xám nhạt) -->
<!-- Trạng thái hoàn thành: Đổi background thành #DCFCE7 và chữ màu #22C55E -->
<StackPane style="-fx-background-color: #DCFCE7; -fx-background-radius: 15; -fx-pref-width: 30; -fx-pref-height: 30;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <Label fx:id="dayLabel" text="M" style="-fx-text-fill: #22C55E; -fx-font-size: 12px; -fx-font-weight: bold;" />
</StackPane>
