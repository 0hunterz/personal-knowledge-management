<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<!-- Mockup của TaskStatCard, ta sẽ truyền icon, màu sắc và text bằng code Java sau. Ở đây design 1 bản mẫu. -->
<HBox spacing="15" alignment="CENTER_LEFT" styleClass="task-stat-card" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    
    <VBox styleClass="stat-icon-wrapper" style="-fx-background-color: #DCFCE7;">
        <Label style="-fx-font-size: 18px; -fx-text-fill: #22C55E;" text="✓" />
    </VBox>
    
    <VBox spacing="2">
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F2937;" text="12" />
        <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" text="Completed" />
        <Label style="-fx-font-size: 10px; -fx-text-fill: #94A3B8;" text="Today" />
    </VBox>
</HBox>
