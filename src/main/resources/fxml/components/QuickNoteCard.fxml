<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" styleClass="card" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="✎" style="-fx-text-fill: #3B82F6; -fx-font-size: 16px;" />
        <Label text="Quick Note" styleClass="card-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="⋮" style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-cursor: hand; -fx-text-fill: #64748B;" />
    </HBox>

    <TextArea fx:id="noteArea" promptText="Write something...&#10;(press Enter to save)" wrapText="true" prefRowCount="4" style="-fx-background-color: transparent; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-control-inner-background: #F8FAFC;" />

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Label fx:id="charCountLabel" text="0 / 200" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8;" />
        <Button text="Save Note" style="-fx-background-color: #E6F8F1; -fx-text-fill: #10B981; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 6 12; -fx-cursor: hand;" />
    </HBox>
</VBox>
