<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox alignment="CENTER_LEFT" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="zen-glass-small">
        <Label styleClass="zen-bottom-title" text="Ambient Sounds" />
        <Label styleClass="zen-muted" text="Rain" />
    </HBox>

    <Region HBox.hgrow="ALWAYS" />

    <HBox alignment="CENTER" maxWidth="360" spacing="12" styleClass="zen-message-pill">
        <Label wrapText="true" styleClass="zen-message-text" text="Small consistent effort brings lasting results." />
    </HBox>

    <Region HBox.hgrow="ALWAYS" />

    <HBox alignment="CENTER" spacing="12" styleClass="zen-glass-small">
        <Label styleClass="zen-bottom-title" text="Volume" />
        <Slider prefWidth="110" value="70" />
        <ProgressBar progress="0.7" prefWidth="60" />
    </HBox>
</HBox>
