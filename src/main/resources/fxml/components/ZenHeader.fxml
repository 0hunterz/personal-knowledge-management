<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox alignment="CENTER_LEFT" spacing="12" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="zen-glass-pill">
        <Label styleClass="zen-brand-mark" text="Focus-Node" />
        <VBox spacing="2">
            <Label styleClass="zen-card-title" text="Zen Mode" />
            <Label styleClass="zen-muted" text="Stay focused. You've got this." />
        </VBox>
    </HBox>

    <Region HBox.hgrow="ALWAYS" />

    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="zen-glass-pill">
        <Label styleClass="zen-muted-icon" text="LAN" />
        <VBox spacing="2">
            <Label styleClass="zen-card-title-small" text="LAN Room: Focus Room A" />
            <Label styleClass="zen-muted" text="4 members focusing" />
        </VBox>
        <Label styleClass="zen-signal" text="||||" />
    </HBox>

    <Region HBox.hgrow="ALWAYS" />

    <Button styleClass="zen-exit-button" text="Exit Zen Mode" />
</HBox>
