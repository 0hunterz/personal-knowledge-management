<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.focusnode.controller.KnowledgeViewController">
    
    <ScrollPane fx:id="notesScrollPane" fitToWidth="true" style="-fx-background-color: #F8FAFC;">
        <HBox spacing="30" style="-fx-padding: 30; -fx-background-color: #F8FAFC;">
        
        <!-- Cột Giữa (Nội dung chính với 2 State) -->
        <StackPane HBox.hgrow="ALWAYS">
            
            <!-- ========================================== -->
            <!-- STATE 1: KNOWLEDGE DASHBOARD               -->
            <!-- ========================================== -->
            <VBox fx:id="dashboardContainer" spacing="30">
                <!-- Header & Quick Capture -->
                <VBox spacing="15">
                    <Label style="-fx-font-family: 'Georgia', serif; -fx-font-weight: bold; -fx-font-size: 32px; -fx-text-fill: #1F2937;" text="Learning Companion" />
                    <TextField fx:id="quickCaptureInput" prefWidth="500" promptText="What's on your mind? Type to capture..." style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 12 20; -fx-font-size: 14px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);" />
                </VBox>
                
                <!-- Continue Learning (Mới thêm) -->
                <VBox spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #374151;" text="Continue Learning" />
                    </HBox>
                    <FlowPane hgap="20" vgap="20">
                        <VBox styleClass="hub-portal-card" onMouseClicked="#openPersonalRepository" prefWidth="250" prefHeight="120" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 15, 0, 0, 6);">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="📄" style="-fx-font-size: 16px;" />
                                <Label text="Product Design" style="-fx-font-size: 11px; -fx-text-fill: #8B5CF6; -fx-font-weight: bold; -fx-background-color: #F3E8FF; -fx-padding: 4 8; -fx-background-radius: 12;" />
                            </HBox>
                            <Region VBox.vgrow="ALWAYS" />
                            <Label text="Mental Models for UX" style="-fx-font-family: 'Georgia', serif; -fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" wrapText="true" />
                        </VBox>
                        <VBox styleClass="hub-portal-card" onMouseClicked="#openPersonalRepository" prefWidth="250" prefHeight="120" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 15, 0, 0, 6);">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="📝" style="-fx-font-size: 16px;" />
                                <Label text="Algorithms" style="-fx-font-size: 11px; -fx-text-fill: #10B981; -fx-font-weight: bold; -fx-background-color: #D1FAE5; -fx-padding: 4 8; -fx-background-radius: 12;" />
                            </HBox>
                            <Region VBox.vgrow="ALWAYS" />
                            <Label text="Dynamic Programming Basics" style="-fx-font-family: 'Georgia', serif; -fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" wrapText="true" />
                        </VBox>
                    </FlowPane>
                </VBox>

                <!-- Portals Grid (Giữ nguyên của người dùng) -->
                <VBox spacing="15">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #374151;" text="Knowledge Hub Portals" />
                    <FlowPane hgap="20" vgap="20">
                        <!-- Personal Repository Portal -->
                        <VBox styleClass="hub-portal-card" onMouseClicked="#openPersonalRepository" prefWidth="250" prefHeight="140" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 20; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                            <Label text="🗂" style="-fx-font-size: 32px;" />
                            <Region VBox.vgrow="ALWAYS" />
                            <Label text="Personal Repository" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1F2937;" />
                            <Label fx:id="repoStatsLbl" text="Loading stats..." style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
                        </VBox>
                        
                        <!-- Shared with me Portal -->
                        <VBox styleClass="hub-portal-card" prefWidth="250" prefHeight="140" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 20; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                            <Label text="🤝" style="-fx-font-size: 32px;" />
                            <Region VBox.vgrow="ALWAYS" />
                            <Label text="Shared with me" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1F2937;" />
                            <Label text="LAN Hub transfers" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
                        </VBox>
                        
                        <!-- Recent Portal -->
                        <VBox styleClass="hub-portal-card" prefWidth="250" prefHeight="140" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 20; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                            <Label text="🕒" style="-fx-font-size: 32px;" />
                            <Region VBox.vgrow="ALWAYS" />
                            <Label text="Recent" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1F2937;" />
                            <Label text="Recently accessed files" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
                        </VBox>

                        <!-- Trash Portal -->
                        <VBox styleClass="hub-portal-card" onMouseClicked="#openTrash" prefWidth="250" prefHeight="140" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 20; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);">
                            <Label text="🗑" style="-fx-font-size: 32px;" />
                            <Region VBox.vgrow="ALWAYS" />
                            <Label text="Trash" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1F2937;" />
                            <Label text="Deleted items" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
                        </VBox>
                    </FlowPane>
                </VBox>
            </VBox>

            <!-- ========================================== -->
            <!-- STATE 2: PERSONAL REPOSITORY               -->
            <!-- ========================================== -->
            <VBox fx:id="personalRepoContainer" spacing="20" visible="false">
                
                <!-- Tiêu đề & Breadcrumb -->
                <VBox spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #1F2937;" text="Personal Repository" />
                    </HBox>
                    <HBox fx:id="breadcrumbContainer" alignment="CENTER_LEFT" spacing="5" style="-fx-padding: 0 0 10 0;">
                        <!-- Custom breadcrumbs will be injected here -->
                    </HBox>
                </VBox>
                
                <!-- Thanh Công cụ (Search, Toggles, Filter, New Note) -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <TextField fx:id="searchInput" prefWidth="350" promptText="🔍 Search in repository..." style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;" />
                    
                    <Region HBox.hgrow="ALWAYS" />
                    
                    <!-- Toggles -->
                    <HBox spacing="5" styleClass="view-toggle-container">
                        <Label fx:id="gridViewBtn" styleClass="toggle-btn, toggle-btn-active" text="⊞" style="-fx-font-size: 18px; -fx-cursor: hand;" />
                        <Label fx:id="listViewBtn" styleClass="toggle-btn" text="≡" style="-fx-font-size: 18px; -fx-cursor: hand;" />
                    </HBox>
                    
                    <MenuButton fx:id="newBtn" text="+ New Note ⌄" style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;">
                        <items>
                            <MenuItem text="📁 New Folder" onAction="#createNewFolder" />
                            <MenuItem text="📝 New Note" onAction="#createNewNote" />
                            <SeparatorMenuItem />
                            <MenuItem text="📤 Upload File" onAction="#uploadFile" />
                        </items>
                    </MenuButton>
                </HBox>
                
                <!-- Quick Filters (Notion style pills) -->
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0;">
                    <Label style="-fx-text-fill: #6B7280; -fx-font-size: 13px;" text="Filters:" />
                    <Label styleClass="notion-filter-pill, notion-filter-pill-active" text="All" />
                    <Label styleClass="notion-filter-pill" text="Folders" />
                    <Label styleClass="notion-filter-pill" text="Notes" />
                </HBox>
                
                <!-- Vùng hiển thị (Grid/List) -->
                <StackPane fx:id="repoContentContainer" VBox.vgrow="ALWAYS">
                    <!-- Lưới Ghi chú và File (Grid View) -->
                    <FlowPane fx:id="notesFlowPane" hgap="20" vgap="20" />
                    
                    <!-- Danh sách Ghi chú và File (List View) -->
                    <VBox fx:id="listViewContainer" spacing="10" visible="false">
                        <!-- Header -->
                        <HBox style="-fx-padding: 10; -fx-border-color: transparent transparent #E5E7EB transparent; -fx-border-width: 0 0 1 0;">
                            <Label text="Name" style="-fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-pref-width: 400;" />
                            <Label text="Type" style="-fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-pref-width: 150;" />
                            <Label text="Last Modified" style="-fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-pref-width: 150;" />
                        </HBox>
                        <!-- List Items -->
                        <VBox fx:id="listItemsBox" spacing="5" />
                    </VBox>
                </StackPane>
            </VBox>
            
        </StackPane>
        
        <!-- Cột Phải (Widgets) -->
        <VBox minWidth="300" prefWidth="300" spacing="20">
            <fx:include source="../components/QuoteCard.fxml" />
            <fx:include source="../components/QuickNoteCard.fxml" />
            <fx:include source="../components/TagsCloudCard.fxml" />
            <fx:include source="../components/StorageCard.fxml" />
        </VBox>
        
    </HBox>
    </ScrollPane>

    <!-- Editor Container (Modal) -->
    <StackPane fx:id="editorContainer" visible="false" style="-fx-background-color: rgba(0,0,0,0.5);" />

</StackPane>
