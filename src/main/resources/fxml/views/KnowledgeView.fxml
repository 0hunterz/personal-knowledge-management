<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.SVGPath?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.focusnode.controller.KnowledgeViewController">
    
    <ScrollPane fx:id="notesScrollPane" fitToWidth="true" style="-fx-background-color: #F8FAFC;">
        <HBox spacing="30" style="-fx-padding: 30; -fx-background-color: #F8FAFC;">
        
        <!-- Cột Giữa (Nội dung chính với 2 State) -->
        <StackPane HBox.hgrow="ALWAYS">
            
            <!-- ========================================== -->
            <!-- STATE 1: KNOWLEDGE DASHBOARD               -->
            <!-- ========================================== -->
            <VBox fx:id="dashboardContainer" spacing="30">
                <!-- Header & Quick Capture -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label style="-fx-font-family: 'Georgia', serif; -fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #1F2937;" text="Learning Companion" />
                    <Label text="✨ improved" style="-fx-font-size: 11px; -fx-text-fill: #047857; -fx-font-weight: bold; -fx-background-color: #D1FAE5; -fx-padding: 4 8; -fx-background-radius: 12;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <StackPane maxWidth="-Infinity" maxHeight="-Infinity" style="-fx-background-color: #FFFFFF; -fx-padding: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;">
                        <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" style="-fx-fill: #9CA3AF;" scaleX="0.9" scaleY="0.9" />
                    </StackPane>
                    <Label text="+ New note" style="-fx-font-weight: bold; -fx-text-fill: #10B981; -fx-background-color: #D1FAE5; -fx-padding: 10 16; -fx-background-radius: 8; -fx-cursor: hand;" />
                </HBox>
                
                <!-- Continue Learning -->
                <VBox spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #374151;" text="▷ Continue Learning" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="View all →" style="-fx-font-size: 12px; -fx-text-fill: #10B981; -fx-cursor: hand;" />
                    </HBox>
                    <HBox spacing="15">
                        <VBox styleClass="hub-portal-card" onMouseClicked="#openPersonalRepository" prefWidth="200" prefHeight="160" spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 15, 0, 0, 6);">
                            <Label text="Algorithms" style="-fx-font-size: 11px; -fx-text-fill: #4F46E5; -fx-font-weight: bold; -fx-background-color: #E0E7FF; -fx-padding: 4 8; -fx-background-radius: 12;" />
                            <Label text="Dynamic Programming Basics" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" wrapText="true" />
                            <Region VBox.vgrow="ALWAYS" />
                            <VBox spacing="5">
                                <HBox alignment="CENTER_LEFT">
                                    <Region style="-fx-background-color: #10B981; -fx-pref-height: 4; -fx-pref-width: 62; -fx-background-radius: 2;" />
                                    <Region style="-fx-background-color: #E5E7EB; -fx-pref-height: 4; -fx-pref-width: 38; -fx-background-radius: 2;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="62%" style="-fx-font-size: 11px; -fx-text-fill: #6B7280; -fx-min-width: 35px; -fx-alignment: center-right;" />
                                </HBox>
                                <Label text="🕒 Last viewed: 2 days ago" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" />
                            </VBox>
                        </VBox>

                        <VBox styleClass="hub-portal-card" onMouseClicked="#openPersonalRepository" prefWidth="200" prefHeight="160" spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 15, 0, 0, 6);">
                            <Label text="Product Design" style="-fx-font-size: 11px; -fx-text-fill: #8B5CF6; -fx-font-weight: bold; -fx-background-color: #F3E8FF; -fx-padding: 4 8; -fx-background-radius: 12;" />
                            <Label text="Mental Models for UX" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" wrapText="true" />
                            <Region VBox.vgrow="ALWAYS" />
                            <VBox spacing="5">
                                <HBox alignment="CENTER_LEFT">
                                    <Region style="-fx-background-color: #10B981; -fx-pref-height: 4; -fx-pref-width: 35; -fx-background-radius: 2;" />
                                    <Region style="-fx-background-color: #E5E7EB; -fx-pref-height: 4; -fx-pref-width: 65; -fx-background-radius: 2;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="35%" style="-fx-font-size: 11px; -fx-text-fill: #6B7280; -fx-min-width: 35px; -fx-alignment: center-right;" />
                                </HBox>
                                <Label text="🕒 Last viewed: 5 days ago" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" />
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Knowledge Hub Portals -->
                <VBox spacing="15">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #374151;" text="🗂 Knowledge Portals" />
                    <FlowPane hgap="15" vgap="15">
                        <VBox styleClass="hub-portal-card" onMouseClicked="#openPersonalRepository" prefWidth="150" prefHeight="160" alignment="CENTER" spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 20, 0, 0, 8);">
                            <StackPane maxWidth="-Infinity" maxHeight="-Infinity" style="-fx-background-color: #D1FAE5; -fx-padding: 10; -fx-background-radius: 12;">
                                <SVGPath content="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" style="-fx-fill: #10B981;" scaleX="1.3" scaleY="1.3" />
                            </StackPane>
                            <Label text="Personal Repo" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" textAlignment="CENTER" wrapText="true" />
                            <Label fx:id="repoStatsLbl" text="42 notes&#10;- 3 folders" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" textAlignment="CENTER" wrapText="true" />
                        </VBox>
                        
                        <VBox styleClass="hub-portal-card" prefWidth="150" prefHeight="160" alignment="CENTER" spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 20, 0, 0, 8);">
                            <StackPane maxWidth="-Infinity" maxHeight="-Infinity" style="-fx-background-color: #E0E7FF; -fx-padding: 10; -fx-background-radius: 12;">
                                <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" style="-fx-fill: #4F46E5;" scaleX="1.3" scaleY="1.3" />
                            </StackPane>
                            <Label text="Shared with me" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" textAlignment="CENTER" wrapText="true" />
                            <Label text="8 files from&#10;LAN Hub" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" textAlignment="CENTER" wrapText="true" />
                        </VBox>
                        
                        <VBox styleClass="hub-portal-card" prefWidth="150" prefHeight="160" alignment="CENTER" spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 20, 0, 0, 8);">
                            <StackPane maxWidth="-Infinity" maxHeight="-Infinity" style="-fx-background-color: #FEF3C7; -fx-padding: 10; -fx-background-radius: 12;">
                                <SVGPath content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" style="-fx-fill: #F59E0B;" scaleX="1.3" scaleY="1.3" />
                            </StackPane>
                            <Label text="Recent" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" textAlignment="CENTER" wrapText="true" />
                            <Label text="Recently&#10;accessed" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" textAlignment="CENTER" wrapText="true" />
                        </VBox>
                        
                        <VBox styleClass="hub-portal-card" onMouseClicked="#openTrash" prefWidth="150" prefHeight="160" alignment="CENTER" spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 20, 0, 0, 8);">
                            <StackPane maxWidth="-Infinity" maxHeight="-Infinity" style="-fx-background-color: #FEE2E2; -fx-padding: 10; -fx-background-radius: 12;">
                                <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" style="-fx-fill: #EF4444;" scaleX="1.3" scaleY="1.3" />
                            </StackPane>
                            <Label text="Trash" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" textAlignment="CENTER" wrapText="true" />
                            <Label text="Deleted&#10;notes" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" textAlignment="CENTER" wrapText="true" />
                        </VBox>
                    </FlowPane>
                </VBox>

                <!-- Recent Notes -->
                <VBox spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #374151;" text="📄 Recent Notes" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="Open vault →" style="-fx-font-size: 12px; -fx-text-fill: #10B981; -fx-cursor: hand;" />
                    </HBox>
                    <VBox spacing="10">
                        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #FFFFFF; -fx-padding: 12; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 15, 0, 0, 6);">
                            <StackPane maxWidth="-Infinity" maxHeight="-Infinity" style="-fx-background-color: #F3E8FF; -fx-padding: 8; -fx-background-radius: 8;">
                                <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" style="-fx-fill: #8B5CF6;" scaleX="1.1" scaleY="1.1" />
                            </StackPane>
                            <VBox spacing="2">
                                <Label text="Dynamic Programming..." style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" />
                                <Label text="Updated 1 hour ago - 1,240 words" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" />
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="#Algorithms" style="-fx-font-size: 11px; -fx-text-fill: #047857; -fx-font-weight: bold; -fx-background-color: #D1FAE5; -fx-padding: 4 8; -fx-background-radius: 12;" />
                        </HBox>
                        
                        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #FFFFFF; -fx-padding: 12; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 15, 0, 0, 6);">
                            <StackPane maxWidth="-Infinity" maxHeight="-Infinity" style="-fx-background-color: #D1FAE5; -fx-padding: 8; -fx-background-radius: 8;">
                                <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" style="-fx-fill: #10B981;" scaleX="1.1" scaleY="1.1" />
                            </StackPane>
                            <VBox spacing="2">
                                <Label text="Heuristics trong UI/UX..." style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1F2937;" />
                                <Label text="Updated yesterday - 850 words" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;" />
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="#Design" style="-fx-font-size: 11px; -fx-text-fill: #4F46E5; -fx-font-weight: bold; -fx-background-color: #E0E7FF; -fx-padding: 4 8; -fx-background-radius: 12;" />
                        </HBox>
                    </VBox>
                </VBox>
            </VBox>

            <!-- ========================================== -->
            <!-- STATE 2: PERSONAL REPOSITORY               -->
            <!-- ========================================== -->
            <VBox fx:id="personalRepoContainer" spacing="20" visible="false">
                
                <!-- Tiêu đề & Breadcrumb -->
                <VBox spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #1F2937;" text="Personal Repository" />
                    </HBox>
                    <HBox fx:id="breadcrumbContainer" alignment="CENTER_LEFT" spacing="5" style="-fx-padding: 0 0 10 0;">
                        <!-- Custom breadcrumbs will be injected here -->
                    </HBox>
                </VBox>
                
                <!-- Thanh Công cụ (Search, Toggles, Filter, New Note) -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <TextField fx:id="searchInput" prefWidth="350" promptText="🔍 Search in repository..." style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12;" />
                    
                    <Region HBox.hgrow="ALWAYS" />
                    
                    <!-- Toggles -->
                    <HBox spacing="5" styleClass="view-toggle-container">
                        <Label fx:id="gridViewBtn" styleClass="toggle-btn, toggle-btn-active" text="⊞" style="-fx-font-size: 18px; -fx-cursor: hand;" />
                        <Label fx:id="listViewBtn" styleClass="toggle-btn" text="≡" style="-fx-font-size: 18px; -fx-cursor: hand;" />
                    </HBox>
                    
                    <MenuButton fx:id="newBtn" text="+ New Note ⌄" style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;">
                        <items>
                            <MenuItem text="📁 New Folder" onAction="#createNewFolder" />
                            <MenuItem text="📝 New Note" onAction="#createNewNote" />
                            <SeparatorMenuItem />
                            <MenuItem text="📤 Upload File" onAction="#uploadFile" />
                        </items>
                    </MenuButton>
                </HBox>
                
                <!-- Quick Filters (Notion style pills) -->
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0;">
                    <Label style="-fx-text-fill: #6B7280; -fx-font-size: 13px;" text="Filters:" />
                    <Label styleClass="notion-filter-pill, notion-filter-pill-active" text="All" />
                    <Label styleClass="notion-filter-pill" text="Folders" />
                    <Label styleClass="notion-filter-pill" text="Notes" />
                </HBox>
                
                <!-- Vùng hiển thị (Grid/List) -->
                <StackPane fx:id="repoContentContainer" VBox.vgrow="ALWAYS">
                    <!-- Lưới Ghi chú và File (Grid View) -->
                    <FlowPane fx:id="notesFlowPane" hgap="20" vgap="20" />
                    
                    <!-- Danh sách Ghi chú và File (List View) -->
                    <VBox fx:id="listViewContainer" spacing="10" visible="false">
                        <!-- Header -->
                        <HBox style="-fx-padding: 10; -fx-border-color: transparent transparent #E5E7EB transparent; -fx-border-width: 0 0 1 0;">
                            <Label text="Name" style="-fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-pref-width: 400;" />
                            <Label text="Type" style="-fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-pref-width: 150;" />
                            <Label text="Last Modified" style="-fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-pref-width: 150;" />
                        </HBox>
                        <!-- List Items -->
                        <VBox fx:id="listItemsBox" spacing="5" />
                    </VBox>
                </StackPane>
            </VBox>
            
        </StackPane>
        
        <!-- Cột Phải (Widgets) -->
        <VBox minWidth="300" prefWidth="300" spacing="20">
            <fx:include source="../components/QuoteCard.fxml" />
            <fx:include source="../components/QuickNoteCard.fxml" />
            <fx:include source="../components/TagsCloudCard.fxml" />
            <fx:include source="../components/StorageCard.fxml" />
        </VBox>
        
    </HBox>
    </ScrollPane>

    <!-- Editor Container (Modal) -->
    <StackPane fx:id="editorContainer" visible="false" style="-fx-background-color: rgba(0,0,0,0.5);" />

</StackPane>
